{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "rootDirectory": "web/frontend",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://httpbin.org/status/503"
    },
    {
      "source": "/api/:path*",
      "destination": "https://httpbin.org/status/503"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
