{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix web/frontend",
  "buildCommand": "npm run build --prefix web/frontend",
  "outputDirectory": "web/frontend/dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "https://httpbin.org/status/503"
    },
    {
      "source": "/api/:path*",
      "destination": "https://httpbin.org/status/503"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
