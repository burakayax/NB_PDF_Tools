    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.13.14",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "javascript-obfuscator": "^5.4.1",
    "tailwindcss": "^4.2.2",
    "typescript": "latest",
    "vite": "latest"
  }
}
