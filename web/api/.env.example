# Bu dosyayı ".env" olarak kopyalayın ve değerleri kendi ortamınıza göre doldurun.
# Gerçek şifre, JWT anahtarı veya API anahtarlarını repoya asla eklemeyin.

# Sunucu
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:4000
COOKIE_DOMAIN=

# Veritabanı (SQLite örneği)
DATABASE_URL="file:./dev.db"

# JWT: en az 32 karakter, üretimde güçlü rastgele değerler kullanın.
# Not: Bu projede tek bir JWT_SECRET yok; erişim ve yenileme için iki ayrı anahtar vardır.
JWT_ACCESS_SECRET=example_access_secret_change_me_min_32_characters_long_01
JWT_REFRESH_SECRET=example_refresh_secret_change_me_min_32_characters_long_02

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_HOURS=24

# E-posta (Gmail için genelde "Uygulama şifresi" kullanın)
EMAIL_USER=example@mail.com
EMAIL_PASS=example_password

# İsteğe bağlı SMTP (EMAIL_* yerine kullanılabilir)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=

SMTP_FROM_NAME=NB PDF TOOLS

# Yönetici gelen kutusu (kayıt / iletişim bildirimleri)
ADMIN_EMAIL=admin@example.com

# İlk kurulumda tek seferlik yönetici hesabı (ikisi de doluysa oluşturulur; boş bırakılabilir)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Google OAuth (web: "Google ile devam et") — boş bırakılırsa devre dışı
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dosya günlüğü
LOG_FILE_PATH=logs/nb-pdf-tools-api.log
LOG_FILE_ENABLED=true
