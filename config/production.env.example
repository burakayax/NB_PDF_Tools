# NB PDF TOOLS — üretim ortamı için ortam değişkenleri özet şablonu
# Kopyalayıp her serviste ayrı .env veya platform gizli değişkenlerine uygulayın.
# Gerçek anahtarları repoya asla eklemeyin.

# ─── Genel ─────────────────────────────────────────────────
NODE_ENV=production

# ─── Kimlik API (web/api) — Node / Express
# PORT=4000
# TRUST_PROXY=1
# FORCE_HTTPS=true
# FRONTEND_ORIGIN=https://app.example.com
# APP_BASE_URL=https://api.example.com
# OAUTH_FRONTEND_REDIRECT_ORIGIN=https://app.example.com
# DATABASE_URL=file:./prod.db
# JWT_ACCESS_SECRET=...min-32-chars...
# JWT_REFRESH_SECRET=...min-32-chars...
# EMAIL_USER=...
# EMAIL_PASS=...
# ADMIN_EMAIL=...
# HTTPS_KEY_PATH=/etc/letsencrypt/live/api.example.com/privkey.pem
# HTTPS_CERT_PATH=/etc/letsencrypt/live/api.example.com/fullchain.pem
# IYZICO_API_KEY=...
# IYZICO_SECRET_KEY=...
# IYZICO_URI=https://api.iyzipay.com

# ─── Vite ön uç (build zamanı) — web/frontend
# VITE_SAAS_API_BASE=https://api.example.com
# VITE_API_BASE=https://pdf-api.example.com

# ─── Python PDF API (web/backend) — uvicorn
# JWT_ACCESS_SECRET=... (Node ile aynı)
# CORS_ORIGINS=https://app.example.com
